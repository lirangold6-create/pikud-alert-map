# Server Configuration
PORT=3000

# Data Collection
POLL_INTERVAL=30000
WAVE_GAP_MS=1200000
MIN_WAVE_CITIES=5

# Caching
HISTORY_CACHE_MS=30000

# ML Training Hyperparameters
EPOCHS=80
BATCH_SIZE=64
LEARNING_RATE=0.001
VALIDATION_SPLIT=0.2
DROPOUT_RATE=0.3
L2_REGULARIZATION=0.001

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

